# YouTube Data API v3 key (required)
YOUTUBE_API_KEY=your_youtube_api_key_here

# RPM (Revenue Per Mille) range for long-form earnings estimation
RPM_LOW=1.00
RPM_HIGH=5.00

# RPM range for YouTube Shorts (much lower than long-form)
RPM_SHORTS_LOW=0.03
RPM_SHORTS_HIGH=0.20

# Portion of revenue attributed to ads (rest is YouTube Premium)
ADS_REVENUE_SHARE=0.95

# General cache TTL in seconds
CACHE_TTL_SECONDS=3600

# HTTP timeout for YouTube API requests in seconds
API_TIMEOUT_SECONDS=10

# Cache TTL per category (seconds)
CACHE_CHANNEL_TTL=86400
CACHE_STATS_TTL=3600
CACHE_VIDEOS_TTL=1800

# Maximum number of cache entries (shared across all categories)
CACHE_MAX_SIZE=1000
